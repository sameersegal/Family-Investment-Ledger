                "OwnerId",
                "SecurityId",
                "AssetId",
                "Symbol",
                "Quantity",
                "FlowDate",
                "CashFlow",
                "FlowType"
            ],
            "properties": {
                "Portfolio": {
                    "type": "string",
                    "enum": [
                        "India",
                        "US"
                    ]
                },
                "OwnerId": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "SecurityId": {
                    "$ref": "#/$defs/Identifier"
                },
                "AssetId": {
                    "$ref": "#/$defs/Identifier"
                },
                "Symbol": {
                    "$ref": "#/$defs/Identifier"
                },
                "Quantity": {
                    "$ref": "#/$defs/NumberOrBlank"
                },
                "FlowDate": {
                    "$ref": "#/$defs/IsoDateTimeOrBlank"
                },
                "CashFlow": {
                    "$ref": "#/$defs/NumberOrBlank"
                },
