                        "LTCG"
                    ]
                },
                "GrossGainINR": {
                    "type": "number"
                },
                "ExemptINR": {
                    "type": "number"
                },
                "TaxableINR": {
                    "type": "number"
                },
                "TaxRate": {
                    "$ref": "#/$defs/TaxRate"
                }
            }
        },
        "CashBalanceRow": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "OwnerId",
                "AccountId",
                "AccountKind",
                "Currency",
                "Balance"
            ],
            "properties": {
                "OwnerId": {
                    "$ref": "#/$defs/Identifier"
                },
                "AccountId": {
                    "$ref": "#/$defs/Identifier"
                },
                "AccountKind": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "Currency": {
                    "$ref": "#/$defs/Identifier"
                },
                "Balance": {
                    "type": "number"
                }
            }
        },
        "XIRRCashflowRow": {
            "type": "object",
            "additionalProperties": false,
            "required": [
