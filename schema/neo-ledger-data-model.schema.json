{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://sameersegal.github.io/neo-ledger/schema/neo-ledger-data-model.schema.json",
    "title": "Neo Ledger Data Model Registry",
    "description": "Reusable JSON Schema definitions for Neo Ledger input tables, derived tables, and the bank-statement parser adapter contract. Validate individual files with fragment refs such as #/$defs/TradesFile or #/$defs/CashMovementsFile.",
    "type": "object",
    "additionalProperties": false,
    "properties": {},
    "$defs": {
        "Identifier": {
            "type": "string",
            "minLength": 1
        },
        "IsoDate": {
            "type": "string",
            "format": "date"
        },
        "IsoDateTimeOrBlank": {
            "oneOf": [
                {
                    "type": "string",
                    "format": "date-time"
                },
                {
                    "type": "string",
                    "const": ""
                }
            ]
        },
        "StringOrBlank": {
            "type": "string"
        },
        "BooleanLike": {
            "oneOf": [
                {
                    "type": "boolean"
                },
                {
                    "type": "string",
                    "enum": [
                        "TRUE",
                        "FALSE",
                        ""
                    ]
                }
            ]
        },
        "NumberOrBlank": {
            "oneOf": [
                {
                    "type": "number"
                },
                {
                    "type": "string",
                    "const": ""
                }
            ]
        },
        "TaxRate": {
            "oneOf": [
                {
                    "type": "string",
                    "pattern": "^(?:\\d+(?:\\.\\d+)?%|SLAB)$"
                },
                {
                    "type": "number",
                    "minimum": 0
                }
            ]
        },
        "FinancialYear": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{4}$"
        },
        "TradeSide": {
            "type": "string",
            "enum": [
                "BUY",
                "SELL"
            ]
        },
        "LotActionType": {
            "type": "string",
            "enum": [
                "SPLIT",
                "BONUS",
                "MERGER",
                "CLASS_REORG",
                "GIFT",
                "TRANSFER"
            ]
        },
        "CashCategory": {
            "type": "string",
            "enum": [
                "DIVIDEND",
                "INTEREST",
                "TAX",
                "FEE",
                "DEPOSIT",
                "WITHDRAWAL",
                "FOREX",
                "OTHER",
                "BUY_SETTLEMENT",
                "SELL_PROCEEDS",
                "SALE_PROCEEDS",
                "REINVESTMENT",
                "REPATRIATION",
                "OPENING_BALANCE"
            ]
        },
        "ConfigRow": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "AssetClass",
                "HoldingPeriod_ST_Days",
                "HoldingPeriod_LT_Days",
                "STCG_Tax_Rate",
                "LTCG_Tax_Rate",
                "LTCG_Exemption_INR",
                "Indexation_Allowed",
                "Tax_Regime_Notes"
            ],
            "properties": {
                "AssetClass": {
                    "$ref": "#/$defs/Identifier"
                },
                "HoldingPeriod_ST_Days": {
                    "type": "number",
                    "minimum": 0
                },
                "HoldingPeriod_LT_Days": {
                    "type": "number",
                    "minimum": 0
                },
                "STCG_Tax_Rate": {
                    "$ref": "#/$defs/TaxRate"
                },
                "LTCG_Tax_Rate": {
                    "$ref": "#/$defs/TaxRate"
                },
                "LTCG_Exemption_INR": {
                    "type": "number",
                    "minimum": 0
                },
                "Indexation_Allowed": {
                    "$ref": "#/$defs/BooleanLike"
                },
                "Tax_Regime_Notes": {
                    "$ref": "#/$defs/StringOrBlank"
                }
            }
        },
        "EntityRow": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "EntityId",
                "EntityType",
                "Name",
                "OwnerId",
                "BrokerId",
                "Country",
                "Currency",
                "AccountKind",
                "IsForeignAccount",
                "FEMACategoryNotes"
            ],
            "properties": {
                "EntityId": {
                    "type": "string"
                },
                "EntityType": {
                    "type": "string",
                    "enum": [
                        "OWNER",
                        "BROKER",
                        "ACCOUNT",
                        ""
                    ]
                },
                "Name": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "OwnerId": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "BrokerId": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "Country": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "Currency": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "AccountKind": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "IsForeignAccount": {
                    "$ref": "#/$defs/BooleanLike"
                },
                "FEMACategoryNotes": {
                    "$ref": "#/$defs/StringOrBlank"
                }
            }
        },
        "SecurityRow": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "SecurityId",
                "Ticker",
                "AssetId",
                "Exchange",
                "Country",
                "AssetClass",
                "TradingCurrency",
                "Name"
            ],
            "properties": {
                "SecurityId": {
                    "$ref": "#/$defs/Identifier"
                },
                "Ticker": {
                    "$ref": "#/$defs/Identifier"
                },
                "AssetId": {
                    "$ref": "#/$defs/Identifier"
                },
                "Exchange": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "Country": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "AssetClass": {
                    "$ref": "#/$defs/Identifier"
                },
                "TradingCurrency": {
                    "$ref": "#/$defs/Identifier"
                },
                "Name": {
                    "$ref": "#/$defs/StringOrBlank"
                }
            }
        },
        "TradeRow": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "TradeId",
                "TradeDate",
                "OwnerId",
                "BrokerId",
                "AccountId",
                "SecurityId",
                "Side",
                "Quantity",
                "Price",
                "Fees",
                "FXRateToINR",
                "Notes",
                "SourceRef"
            ],
            "properties": {
                "TradeId": {
                    "$ref": "#/$defs/Identifier"
                },
                "TradeDate": {
                    "$ref": "#/$defs/IsoDate"
                },
                "OwnerId": {
                    "$ref": "#/$defs/Identifier"
                },
                "BrokerId": {
                    "$ref": "#/$defs/Identifier"
                },
                "AccountId": {
                    "$ref": "#/$defs/Identifier"
                },
                "SecurityId": {
                    "$ref": "#/$defs/Identifier"
                },
                "Side": {
                    "$ref": "#/$defs/TradeSide"
                },
                "Quantity": {
                    "type": "number",
                    "exclusiveMinimum": 0
                },
                "Price": {
                    "type": "number",
                    "minimum": 0
                },
                "Fees": {
                    "type": "number",
                    "minimum": 0
                },
                "FXRateToINR": {
                    "type": "number",
                    "exclusiveMinimum": 0
                },
                "Notes": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "SourceRef": {
                    "$ref": "#/$defs/StringOrBlank"
                }
            }
        },
        "LotActionRow": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "ActionId",
                "ActionDate",
                "ActionType",
                "OwnerFromId",
                "OwnerToId",
                "BrokerFromId",
                "BrokerToId",
                "AccountFromId",
                "AccountToId",
                "SecurityId",
                "SecurityToId",
                "SplitNumerator",
                "SplitDenominator",
                "Quantity",
                "Notes",
                "SourceRef"
            ],
            "properties": {
                "ActionId": {
                    "$ref": "#/$defs/Identifier"
                },
                "ActionDate": {
                    "$ref": "#/$defs/IsoDate"
                },
                "ActionType": {
                    "$ref": "#/$defs/LotActionType"
                },
                "OwnerFromId": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "OwnerToId": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "BrokerFromId": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "BrokerToId": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "AccountFromId": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "AccountToId": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "SecurityId": {
                    "$ref": "#/$defs/Identifier"
                },
                "SecurityToId": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "SplitNumerator": {
                    "$ref": "#/$defs/NumberOrBlank"
                },
                "SplitDenominator": {
                    "$ref": "#/$defs/NumberOrBlank"
                },
                "Quantity": {
                    "$ref": "#/$defs/NumberOrBlank"
                },
                "Notes": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "SourceRef": {
                    "$ref": "#/$defs/StringOrBlank"
                }
            }
        },
        "CashMovementRow": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "CashTxnId",
                "TxnDate",
                "OwnerId",
                "AccountId",
                "Currency",
                "Amount",
                "Category",
                "LinkedTradeId",
                "LinkedActionId",
                "IsForeignIncome",
                "Notes",
                "SourceRef"
            ],
            "properties": {
                "CashTxnId": {
                    "$ref": "#/$defs/Identifier"
                },
                "TxnDate": {
                    "$ref": "#/$defs/IsoDate"
                },
                "OwnerId": {
                    "$ref": "#/$defs/Identifier"
                },
                "AccountId": {
                    "$ref": "#/$defs/Identifier"
                },
                "Currency": {
                    "$ref": "#/$defs/Identifier"
                },
                "Amount": {
                    "type": "number"
                },
                "Category": {
                    "$ref": "#/$defs/CashCategory"
                },
                "LinkedTradeId": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "LinkedActionId": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "IsForeignIncome": {
                    "$ref": "#/$defs/BooleanLike"
                },
                "Notes": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "SourceRef": {
                    "$ref": "#/$defs/StringOrBlank"
                }
            }
        },
        "PriceRow": {
            "type": "object",
            "additionalProperties": true,
            "required": [
                "SecurityId",
                "Price"
            ],
            "properties": {
                "SecurityId": {
                    "$ref": "#/$defs/Identifier"
                },
                "Price": {
                    "type": "number",
                    "minimum": 0
                },
                "Currency": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "FXRate": {
                    "$ref": "#/$defs/NumberOrBlank"
                }
            }
        },
        "AssertionRow": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "type",
                "desc"
            ],
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "quantity",
                        "no_negative",
                        "no_invalid"
                    ]
                },
                "owner": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "security": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "account": {
                    "$ref": "#/$defs/StringOrBlank"
                },
                "expected": {
                    "type": "number"
                },
                "desc": {
                    "$ref": "#/$defs/Identifier"
                }
            },
            "allOf": [
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "quantity"
                            }
                        }
                    },
                    "then": {
                        "required": [
                            "owner",
                            "security",
                            "account",
                            "expected"
                        ]
                    }
                }
            ]
        },
        "LotCurrentRow": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "LotId",
                "OwnerId",
                "SecurityId",
                "AssetId",
                "BuyDate",
                "OpenQty",
                "CostNative",
                "CostPriceNative",
                "CostINR",
                "BuyFXRate",
                "BrokerId",
                "AccountId"
            ],
            "properties": {
                "LotId": {
                    "$ref": "#/$defs/Identifier"
                },
                "OwnerId": {
                    "$ref": "#/$defs/Identifier"
                },
                "SecurityId": {
                    "$ref": "#/$defs/Identifier"
                },
                "AssetId": {
                    "$ref": "#/$defs/Identifier"
                },
                "BuyDate": {
                    "$ref": "#/$defs/IsoDate"
                },
                "OpenQty": {
                    "type": "number",
                    "minimum": 0
                },
                "CostNative": {
                    "type": "number"
                },
                "CostPriceNative": {
                    "type": "number"
                },
                "CostINR": {
                    "type": "number"
                },
                "BuyFXRate": {
                    "type": "number",
                    "exclusiveMinimum": 0
                },
                "BrokerId": {
                    "$ref": "#/$defs/Identifier"
                },
                "AccountId": {
                    "$ref": "#/$defs/Identifier"
                }
            }
        },
        "LotConsumeRow": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "ConsumeId",
                "TradeId",
                "OwnerId",
                "SecurityId",
                "AssetId",
                "LotId",
                "BuyDate",
                "SellDate",
                "Quantity",
                "CostNative",
                "CostPriceNative",
                "CostINR",
                "CostFXRate",
                "SalePriceNative",
                "SaleFXRate",
                "ProceedsNative",
                "ProceedsINR"
            ],
            "properties": {
                "ConsumeId": {
                    "$ref": "#/$defs/Identifier"
                },
                "TradeId": {
                    "$ref": "#/$defs/Identifier"
                },
                "OwnerId": {
                    "$ref": "#/$defs/Identifier"
                },
                "SecurityId": {
                    "$ref": "#/$defs/Identifier"
                },
                "AssetId": {
                    "$ref": "#/$defs/Identifier"
                },
                "LotId": {
                    "$ref": "#/$defs/Identifier"
                },
                "BuyDate": {
                    "$ref": "#/$defs/IsoDate"
                },
                "SellDate": {
                    "$ref": "#/$defs/IsoDate"
                },
                "Quantity": {
                    "type": "number",
                    "exclusiveMinimum": 0
                },
                "CostNative": {
                    "type": "number"
                },
                "CostPriceNative": {
                    "type": "number"
                },
                "CostINR": {
                    "type": "number"
                },
                "CostFXRate": {
                    "oneOf": [
                        {
                            "type": "number",
                            "exclusiveMinimum": 0
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "SalePriceNative": {
                    "type": "number"
                },
                "SaleFXRate": {
                    "type": "number",
                    "exclusiveMinimum": 0
                },
                "ProceedsNative": {
                    "type": "number"
                },
                "ProceedsINR": {
                    "type": "number"
                }
            }
        },
        "GainRealizedRow": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "OwnerId",
                "SecurityId",
                "LotId",
                "BuyDate",
                "SellDate",
                "Quantity",
                "CostINR",
                "ProceedsINR",
                "GainINR",
                "HoldingDays",
                "GainType",
                "AssetClass",
                "FinancialYear"
            ],
            "properties": {
                "OwnerId": {
                    "$ref": "#/$defs/Identifier"
                },
                "SecurityId": {
                    "$ref": "#/$defs/Identifier"
                },
                "LotId": {
                    "$ref": "#/$defs/Identifier"
                },
                "BuyDate": {
                    "$ref": "#/$defs/IsoDate"
                },
                "SellDate": {
                    "$ref": "#/$defs/IsoDate"
                },
                "Quantity": {
                    "type": "number",
                    "exclusiveMinimum": 0
                },
                "CostINR": {
                    "type": "number"
                },
                "ProceedsINR": {
                    "type": "number"
                },
                "GainINR": {
                    "type": "number"
                },
                "HoldingDays": {
                    "type": "integer",
                    "minimum": 0
                },
                "GainType": {
                    "type": "string",
                    "enum": [
                        "STCG",
                        "LTCG"
                    ]
                },
                "AssetClass": {
                    "$ref": "#/$defs/Identifier"
                },
                "FinancialYear": {
                    "$ref": "#/$defs/FinancialYear"
                }
            }
        },
        "TaxSummaryFYRow": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "OwnerId",
                "FinancialYear",
                "AssetClass",
                "GainType",
                "GrossGainINR",
                "ExemptINR",
                "TaxableINR",
                "TaxRate"
            ],
