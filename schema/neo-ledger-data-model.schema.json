        },
        "SensitivityLotRow": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "OwnerId",
                "Ticker",
                "BuyDate",
                "Qty",
                "CostINR",
                "Type",
                "ToLTCG",
                "ValueINR",
                "GainINR",
                "TaxINR"
            ],
            "properties": {
                "OwnerId": {
                    "$ref": "#/$defs/Identifier"
                },
                "Ticker": {
                    "$ref": "#/$defs/Identifier"
                },
                "BuyDate": {
                    "$ref": "#/$defs/IsoDate"
                },
                "Qty": {
                    "type": "number",
                    "exclusiveMinimum": 0
                },
                "CostINR": {
                    "type": "number",
                    "minimum": 0
                },
                "Type": {
                    "type": "string",
                    "enum": [
                        "L",
                        "S"
                    ]
                },
                "ToLTCG": {
                    "oneOf": [
                        {
                            "type": "integer",
                            "minimum": 1
                        },
                        {
                            "type": "string",
                            "const": ""
                        }
                    ]
                },
                "ValueINR": {
                    "$ref": "#/$defs/NumberOrBlank"
                },
                "GainINR": {
                    "$ref": "#/$defs/NumberOrBlank"
                },
                "TaxINR": {
                    "$ref": "#/$defs/NumberOrBlank"
                }
            }
        },
        "SensitivityDataDocument": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "meta",
                "lots"
            ],
            "properties": {
                "meta": {
                    "$ref": "#/$defs/Identifier"
                },
                "lots": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/SensitivityLotRow"
                    }
                }
            }
        },
        "SensitivitySummaryRow": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "OwnerId",
                "Ticker",
                "TotalQty",
                "TotalCostINR",
                "TotalValueINR",
                "TotalGainINR",
                "GainPct",
                "TotalTaxINR",
                "LotCount",
                "TypeMix"
            ],
            "properties": {
                "OwnerId": {
                    "$ref": "#/$defs/Identifier"
                },
                "Ticker": {
                    "$ref": "#/$defs/Identifier"
                },
                "TotalQty": {
                    "type": "number",
                    "minimum": 0
                },
                "TotalCostINR": {
