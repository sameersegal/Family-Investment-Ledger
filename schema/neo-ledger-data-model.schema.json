            ],
            "properties": {
                "OwnerId": {
                    "$ref": "#/$defs/Identifier"
                },
                "StartDate": {
                    "$ref": "#/$defs/IsoDate"
                },
                "RemainingAmount": {
                    "type": "number",
                    "exclusiveMinimum": 0
                },
                "AgeDays": {
                    "$ref": "#/$defs/NumberOrBlank"
                },
                "Status": {
                    "$ref": "#/$defs/StringOrBlank"
                }
