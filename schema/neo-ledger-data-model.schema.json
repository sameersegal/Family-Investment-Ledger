            ],
            "properties": {
                "OwnerId": {
                    "$ref": "#/$defs/Identifier"
                },
                "AccountId": {
                    "$ref": "#/$defs/Identifier"
                },
                "BrokerId": {
                    "$ref": "#/$defs/Identifier"
                },
                "Symbol": {
                    "$ref": "#/$defs/Identifier"
                },
                "Quantity": {
                    "type": "number",
                    "minimum": 0
                },
                "SecurityId": {
                    "$ref": "#/$defs/Identifier"
                }
